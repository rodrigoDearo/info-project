# App
PORT=3000
NODE_ENV=development

# SQL Server
DB_HOST=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd
DB_NAME=fleet_db

# MongoDB
MONGODB_URI=mongodb://localhost:27017/fleet_audit

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL_SECONDS=300

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=8h

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_VEHICLE_QUEUE=vehicle_events
